    "@material/mwc-select": "^0.27.0",
    "@material/mwc-switch": "^0.27.0",
    "@material/mwc-tab": "^0.27.0",
    "@material/mwc-tab-bar": "^0.27.0",
    "@material/mwc-textfield": "^0.27.0",
    "color": "^4.2.3",
